# Copy to `.env.public-bridge.local`, fill in real values locally, then:
#   set -a; source .env.public-bridge.local; set +a

# Public Sepolia bridge deployment
AEGISLINK_RELAYER_EVM_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-key
AEGISLINK_RELAYER_EVM_VERIFIER_ADDRESS=0xyour_deployed_verifier
AEGISLINK_RELAYER_EVM_GATEWAY_ADDRESS=0xyour_deployed_gateway
AEGISLINK_RELAYER_EVM_CONFIRMATIONS=2
# Optional for the redeem path. The relayer will sign Sepolia release txs with this key.
# AEGISLINK_RELAYER_EVM_RELEASE_SIGNER_PRIVATE_KEY=0xyour_release_signer_private_key
# AEGISLINK_RELAYER_EVM_RELEASE_SIGNER_ADDRESS=0xyour_release_signer_address

# Relayer behavior
AEGISLINK_RELAYER_COSMOS_CHAIN_ID=aegislink-public-testnet-1
AEGISLINK_RELAYER_SUBMISSION_RETRY_LIMIT=3
AEGISLINK_RELAYER_REPLAY_STORE_PATH=/tmp/aegislink-public-relayer/replay.json
AEGISLINK_RELAYER_ATTESTATION_STATE_PATH=/tmp/aegislink-public-relayer/attestations.json

# AegisLink runtime command. Prefer pointing the relayer at the running demo node.
# The ready file is written by `scripts/testnet/start_aegislink_ibc_demo.sh`.
AEGISLINK_RELAYER_AEGISLINK_CMD=go
AEGISLINK_RELAYER_AEGISLINK_CMD_ARGS='run ./chain/aegislink/cmd/aegislinkd --home /tmp/aegislink-public-home --demo-node-ready-file /tmp/aegislink-public-home/data/demo-node-ready.json'

# Optional automatic AegisLink -> Osmosis delivery after a claimed deposit is credited.
# Auto-delivery turns on automatically when AEGISLINK_RELAYER_RLY_HOME is set.
# AEGISLINK_RELAYER_AUTODELIVERY_ENABLED=true
AEGISLINK_RELAYER_RLY_CMD=./bin/relayer
AEGISLINK_RELAYER_RLY_HOME=/tmp/aegislink-live-rly
AEGISLINK_RELAYER_RLY_PATH_NAME=osmosis-public-wallet
AEGISLINK_RELAYER_IBC_TIMEOUT_HEIGHT=120

# Optional only when you are not using --home in the command args above.
# AEGISLINK_RELAYER_AEGISLINK_STATE_PATH=/tmp/aegislink-public-home/data/runtime.json
