# Copy to `.env.sepolia.deploy.local`, fill in real values locally, then:
#   set -a; source .env.sepolia.deploy.local; set +a

AEGISLINK_SEPOLIA_CHAIN_ID=11155111
AEGISLINK_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-key
AEGISLINK_SEPOLIA_PRIVATE_KEY=0xyour_private_key

# Optional overrides. If omitted, the deploy script derives sensible defaults.
AEGISLINK_SEPOLIA_DEPLOYER_ADDRESS=0xyour_deployer_address
AEGISLINK_SEPOLIA_ATTESTER_ADDRESS=0xyour_attester_address

# Output locations for generated public-testnet metadata.
AEGISLINK_SEPOLIA_DEPLOY_OUTPUT=deploy/testnet/sepolia/bridge-addresses.json
AEGISLINK_SEPOLIA_ASSET_REGISTRY=deploy/testnet/sepolia/bridge-assets.json

# Optional. Leave blank for ETH-only testing, or set a real 0x... Sepolia ERC-20 address later.
AEGISLINK_SEPOLIA_ERC20_ADDRESS=
